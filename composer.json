{
    "name": "psc-acme/lib-product",
    "description": "Package lib-product for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\LibProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/string": "^7.0",
        "monolog/monolog": "^3.2.0",
        "vlucas/phpdotenv": "^5.0",
        "symfony/yaml": "^7.0",
        "psc-acme/driver-cart": "^1.0",
        "psc-acme/validator-cart": "^1.0",
        "psc-acme/provider-cart": "^1.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}